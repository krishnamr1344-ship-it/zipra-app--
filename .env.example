# Zipra production backend (FastAPI on Cloud Run + Supabase PostgreSQL)
NEXT_PUBLIC_API_BASE_URL=https://zipra-api-583825347591.asia-south1.run.app

# Firebase Configuration (from Firebase Console > Project Settings > General > Your apps > Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=zipra-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zipra-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=zipra-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=960066265854
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google OAuth Client IDs (from Google Cloud Console > APIs & Services > Credentials)
# Web client ID is needed for Android Google Sign-In serverClientId
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Admin email for role-based access control
NEXT_PUBLIC_ADMIN_EMAIL=mrselva133@gmail.com
